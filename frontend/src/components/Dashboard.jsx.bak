const resource3 = "https://images.unsplash.com/photo-1622675363311-3e1904dc1885?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80";
const backgroundPattern = "https://images.unsplash.com/photo-1557683316-973673baf926?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80";

const Dashboard = () => {
  const { user, logout, isAdmin } = useContext(AuthContext);
  const navigate = useNavigate();
  const [greeting, setGreeting] = useState("");
  const [showNotifications, setShowNotifications] = useState(false);
  const [currentTime, setCurrentTime] = useState(new Date());
  const [activeTab, setActiveTab] = useState("dashboard");
  const [selectedView, setSelectedView] = useState("grid");
  const [hoveredCard, setHoveredCard] = useState(null);
  const [studyStreak, setStudyStreak] = useState(7);
  const [todayProgress, setTodayProgress] = useState(65);

  useEffect(() => {
    const hour = new Date().getHours();
    if (hour < 12) setGreeting("Good morning");
    else if (hour < 18) setGreeting("Good afternoon");
    else setGreeting("Good evening");

    const timer = setInterval(() => {
      setCurrentTime(new Date());
    }, 60000);

    return () => clearInterval(timer);
  }, []);

  const handleLogout = () => {
    logout();
    navigate("/login");
  };

  const formatTime = (date) => {
    return date.toLocaleTimeString('en-US', { 
      hour: 'numeric', 
      minute: '2-digit',
      hour12: true 
    });
  };

  const formatDate = (date) => {
    return date.toLocaleDateString('en-US', { 
      weekday: 'long',
      month: 'long', 
      day: 'numeric' 
    });
  };

  // Enhanced study groups with images
  const studyGroups = [
    {
      id: 1,
      name: "Advanced Calculus",
      members: 24,
      online: 8,
      image: studyGroup1,
      topic: "Integration Techniques",
      nextSession: "Today 3:00 PM",
      color: "from-blue-500 to-cyan-500"
    },
    {
      id: 2,
      name: "Physics Quantum Mechanics",
      members: 18,
      online: 5,
      image: studyGroup2,
      topic: "Wave Functions",
      nextSession: "Tomorrow 10:00 AM",
      color: "from-purple-500 to-pink-500"
    },
    {
