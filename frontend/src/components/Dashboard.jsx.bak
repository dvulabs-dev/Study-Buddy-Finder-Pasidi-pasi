                  <div>
                    <p className="text-xs text-white/40">Study Hours</p>
                    <p className="text-xl font-bold text-white">127</p>
                    <p className="text-xs text-green-400">↑ +12%</p>
                  </div>
                  <div>
                    <p className="text-xs text-white/40">Groups</p>
                    <p className="text-xl font-bold text-white">8</p>
                    <p className="text-xs text-green-400">↑ +3</p>
                  </div>
                </div>
              </div>
            </div>
