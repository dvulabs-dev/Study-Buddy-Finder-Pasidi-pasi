      status: "away",
      lastActive: "5m ago",
      match: 88,
      mutual: 1
    },
    {
      name: "Sophia Chen",
      avatar: buddy3,
      subjects: ["Chemistry", "Biology"],
      status: "online",
      lastActive: "now",
      match: 92,
      mutual: 4
