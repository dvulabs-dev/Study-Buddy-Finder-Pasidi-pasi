    { name: "Messages", icon: ChatBubbleLeftRightIcon, path: "/messages", badge: 3 },
    { name: "Calendar", icon: CalendarIcon, path: "/calendar" },
    { name: "Analytics", icon: ChartBarIcon, path: "/analytics" }
