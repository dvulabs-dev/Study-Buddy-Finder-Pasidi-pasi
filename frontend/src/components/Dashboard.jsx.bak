    },
    {
      title: "Algorithm Cheat Sheet",
      author: "Tech Community",
      image: resource3,
      type: "PDF",
      pages: 12,
      downloads: 324,
      rating: 4.9
    }
  ];

  // Activity feed
  const activities = [
    {
      user: "Sarah Johnson",
      action: "joined",
      target: "Advanced Calculus",
      time: "2 minutes ago",
      avatar: buddy1,
      type: "join"
    },
    {
      user: "Mike Chen",
      action: "shared",
      target: "Physics Notes",
      time: "15 minutes ago",
      avatar: buddy2,
