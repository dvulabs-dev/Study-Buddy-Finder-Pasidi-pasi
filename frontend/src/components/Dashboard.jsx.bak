                { label: "Study Buddies", value: "24", icon: UserIcon, change: "+5", color: "green" },
                { label: "Hours This Week", value: "18.5", icon: ClockIcon, change: "+3.5", color: "purple" },
                { label: "Resources", value: "47", icon: DocumentTextIcon, change: "+8", color: "pink" }
