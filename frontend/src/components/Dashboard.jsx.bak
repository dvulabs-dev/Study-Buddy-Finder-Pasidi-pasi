                    </span>
                  </div>

                  <div className="space-y-4">
                    {studyBuddies.map((buddy, idx) => (
                      <div 
                        key={idx}
                        className="flex items-center justify-between p-3 transition-all cursor-pointer group hover:bg-white/5 rounded-xl"
                      >
                        <div className="flex items-center space-x-3">
                          <div className="relative">
                            <img 
                              src={buddy.avatar} 
                              alt={buddy.name} 
                              className="object-cover w-12 h-12 rounded-xl"
                            />
                            <div className={`absolute -bottom-1 -right-1 h-3 w-3 ${
                              buddy.status === 'online' ? 'bg-green-500' : 'bg-yellow-500'
                            } border-2 border-white/20 rounded-full`}></div>
                          </div>
                          <div>
                            <p className="text-sm font-medium text-white">{buddy.name}</p>
                            <p className="text-xs text-white/40">{buddy.subjects.join(", ")}</p>
                            <div className="flex items-center mt-1 space-x-2">
                              <span className="text-xs text-green-400">{buddy.match}% match</span>
                              <span className="text-xs text-white/40">• {buddy.mutual} mutual</span>
                            </div>
                          </div>
                        </div>
                        <button className="p-2 text-indigo-400 transition-opacity rounded-lg opacity-0 bg-indigo-500/20 group-hover:opacity-100 hover:bg-indigo-500/30">
                          <PlusIcon className="w-4 h-4" />
                        </button>
                      </div>
                    ))}
                  </div>

                  <button className="w-full py-2 mt-4 text-sm font-medium text-center text-indigo-400 border-t hover:text-indigo-300 border-white/10">
                    View more suggestions
                  </button>
                </div>

                {/* Recent Activity */}
                <div className="p-6 border bg-white/10 backdrop-blur-xl rounded-2xl border-white/20">
                  <h3 className="mb-6 text-lg font-bold text-white">Recent Activity</h3>
                  
                  <div className="space-y-4">
                    {activities.map((activity, idx) => (
                      <div key={idx} className="flex items-start p-2 space-x-3 transition-all group hover:bg-white/5 rounded-xl">
                        <img 
                          src={activity.avatar} 
                          alt={activity.user} 
                          className="object-cover w-8 h-8 rounded-lg"
                        />
                        <div className="flex-1">
                          <p className="text-sm text-white">
                            <span className="font-medium">{activity.user}</span>{' '}
                            <span className="text-white/60">{activity.action}</span>{' '}
                            <span className="font-medium text-indigo-400">{activity.target}</span>
                          </p>
                          <p className="mt-1 text-xs text-white/40">{activity.time}</p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                {/* Study Tips */}
                <div className="p-6 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl">
                  <div className="flex items-center mb-4 space-x-2">
                    <LightBulbIcon className="w-5 h-5 text-white" />
                    <h4 className="font-bold text-white">Pro Tip</h4>
                  </div>
                  <p className="mb-4 text-sm text-indigo-100">
                    Break your study sessions into 25-minute focused intervals with 5-minute breaks. This technique, known as the Pomodoro method, can improve retention by up to 40%.
                  </p>
                  <button className="flex items-center text-sm font-medium text-white hover:underline">
                    Learn more
                    <ChevronRightIcon className="w-4 h-4 ml-1" />
                  </button>
                </div>

                {/* Upcoming Session */}
                <div className="p-6 border bg-white/10 backdrop-blur-xl rounded-2xl border-white/20">
                  <h3 className="mb-4 text-lg font-bold text-white">Next Session</h3>
                  <div className="p-4 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-xl">
                    <p className="mb-1 text-xs text-white/80">Today at 3:00 PM</p>
                    <p className="mb-2 text-lg font-bold text-white">Advanced Calculus</p>
                    <p className="mb-3 text-sm text-white/80">Integration Techniques • 4 participants</p>
                    <button className="w-full px-4 py-2 font-medium text-blue-600 transition-all bg-white rounded-lg hover:shadow-lg">
                      Join Session
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Mobile Menu Button (for small screens) */}
      <button className="fixed z-50 p-4 rounded-full shadow-lg lg:hidden bottom-6 right-6 bg-gradient-to-r from-indigo-600 to-purple-600">
        <AcademicCapIcon className="w-6 h-6 text-white" />
      </button>

      <style jsx>{`
        @keyframes slideDown {
          from {
            opacity: 0;
            transform: translateY(-10px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
        .animate-slideDown {
          animation: slideDown 0.3s ease-out;
        }
        .line-clamp-2 {
          display: -webkit-box;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }
      `}</style>
    </div>
  );
};

export default Dashboard;